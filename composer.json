{
    "name": "goalgorilla/social_template",
    "description": "Social project template for composer based Open Social projects.",
    "type": "project",
    "license": "GPL-2.0+",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "goalgorilla/open_social": "~13.0.0",
        "php": "^8.3",
        "monolog/monolog": "^2.3.5",
        "drush/drush": "^13.7",
        "drupal/ai": "dev-1.3.x",
        "drupal/ai_agents": "dev-1.3.x",
        "drupal/key": "^1.19",
        "drupal/ai_provider_deepseek": "dev-1.x",
        "drupal/ai_provider_ollama": "dev-1.2.x",
        "drupal/ai_vdb_provider_milvus": "dev-1.1.x",
        "drupal/ai_usage_limits": "dev-1.0.x",
        "drupal/ai_file_to_text": "^1.0",
        "drupal/ai_provider_openai": "^1.2",
        "drupal/search_api": "^1.40",
        "drupal/gemini_provider": "1.x-dev",
        "league/commonmark": "^2.8"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        },
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "html/"
            }
        },
        "installer-types": [
            "bower-asset",
            "npm-asset"
        ],
        "installer-paths": {
            "html/core": [
                "drupal/core"
            ],
            "html/modules/contrib/{$name}": [
                "type:drupal-module"
            ],
            "html/profiles/contrib/social": [
                "goalgorilla/open_social"
            ],
            "html/profiles/contrib/{$name}": [
                "type:drupal-profile"
            ],
            "html/themes/contrib/{$name}": [
                "type:drupal-theme"
            ],
            "html/libraries/{$name}": [
                "type:drupal-library",
                "type:bower-asset",
                "type:npm-asset"
            ],
            "drush/contrib/{$name}": [
                "type:drupal-drush"
            ]
        },
        "enable-patching": true,
        "patchLevel": {
            "drupal/core": "-p2"
        },
        "patches": {
            "drupal/gemini_provider": {
                "Add chat_with_tools support, fix response role and tool role mapping": "patches/gemini-provider-chat-with-tools-and-roles.patch"
            },
            "drupal/ai": {
                "Fix deepchat infinite loop, add agent max_loops guard, verbose mode, null safety": "patches/ai-deepchat-and-agent-fixes.patch"
            },
            "drupal/ai_vdb_provider_milvus": {
                "Fix IN/NOT IN operator handling for Milvus filter expressions": "patches/milvus-provider-fix-in-operator-filter.patch"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "cweagans/composer-patches": true,
            "drupal/core-composer-scaffold": true,
            "oomphinc/composer-installers-extender": true,
            "zaporylie/composer-drupal-optimizations": true
        }
    }
}
