<?php

/**
 * @file
 * Install and update functions for the LocalNodes Platform module.
 */

/**
 * Implements hook_install().
 *
 * Sets default AI provider config and applies environment variable overrides.
 * Dependencies (ai, gemini_provider, ai_vdb_provider_qdrant, etc.) install
 * their own empty/default configs first. This function fills in the values
 * our stack requires (Gemini models, Qdrant connection, Solr connection).
 */
function localnodes_platform_install() {
  _localnodes_platform_configure_ai_defaults();
  // Environment-specific overrides (Solr host, Qdrant host, etc.) are handled
  // by $config[] overrides in settings.php, which take effect at runtime without
  // writing to the database. No need to apply them here.
  _localnodes_platform_grant_chatbot_access();
}

/**
 * Grants chatbot API access to anonymous and authenticated users.
 *
 * The 'access deepchat api' permission is required for the AI chatbot widget.
 * We grant it here rather than in config/install because the role entities
 * already exist from the Open Social install profile.
 */
function _localnodes_platform_grant_chatbot_access() {
  $roles = ['anonymous', 'authenticated'];
  foreach ($roles as $role_id) {
    $role = \Drupal\user\Entity\Role::load($role_id);
    if ($role && !$role->hasPermission('access deepchat api')) {
      $role->grantPermission('access deepchat api');
      $role->save();
    }
  }
}

/**
 * Configures AI provider defaults.
 *
 * Sets Gemini as the default provider for all AI operations, configures
 * the Gemini API key reference, and sets Qdrant as the default VDB with
 * DDEV-compatible connection defaults.
 */
function _localnodes_platform_configure_ai_defaults() {
  $config_factory = \Drupal::configFactory();

  // AI settings: set Gemini as default provider for all operations.
  $ai_config = $config_factory->getEditable('ai.settings');
  $ai_config->set('default_providers', [
    'chat' => [
      'provider_id' => 'gemini',
      'model_id' => 'models/gemini-3-flash-preview',
    ],
    'chat_with_complex_json' => [
      'provider_id' => 'gemini',
      'model_id' => 'models/gemini-3-flash-preview',
    ],
    'chat_with_image_vision' => [
      'provider_id' => 'gemini',
      'model_id' => 'models/gemini-3-flash-preview',
    ],
    'chat_with_structured_response' => [
      'provider_id' => 'gemini',
      'model_id' => 'models/gemini-3-flash-preview',
    ],
    'chat_with_tools' => [
      'provider_id' => 'gemini',
      'model_id' => 'models/gemini-3-flash-preview',
    ],
    'embeddings' => [
      'provider_id' => 'gemini',
      'model_id' => 'models/gemini-embedding-001',
    ],
    'speech_to_text' => [
      'provider_id' => 'gemini',
      'model_id' => 'models/gemini-3-flash-preview',
    ],
    'text_to_image' => [
      'provider_id' => 'gemini',
      'model_id' => 'models/gemini-3.1-flash-image-preview',
    ],
  ]);
  $ai_config->set('default_vdb_provider', 'qdrant');
  $ai_config->save(TRUE);

  // Gemini provider: point to Key module's env-based key.
  $gemini_config = $config_factory->getEditable('gemini_provider.settings');
  $gemini_config->set('api_key', 'gemini_api_key');
  $gemini_config->save(TRUE);

  // Qdrant: set DDEV defaults.
  $qdrant_config = $config_factory->getEditable('ai_vdb_provider_qdrant.settings');
  $qdrant_config->set('host', 'qdrant');
  $qdrant_config->set('port', 6333);
  $qdrant_config->save(TRUE);
}

// _localnodes_platform_apply_env_overrides() removed — environment-specific
// connection config (Solr host/port, Qdrant host/port) is handled by $config[]
// overrides in settings.php (generated by the Docker entrypoint). This is
// strictly superior: runtime-only, doesn't pollute the config DB, and can't
// be accidentally overwritten by config:import --partial.
