<?php

/**
 * @file
 * Primary module hooks for Social AI Indexing.
 */

/**
 * Implements hook_theme().
 */
function social_ai_indexing_theme(): array {
  return [
    'social_ai_related_content' => [
      'variables' => [
        'items' => [],
      ],
    ],
    'block__social_ai_related_content' => [
      'base hook' => 'block',
    ],
  ];
}

/**
 * Implements hook_preprocess_block().
 */
function social_ai_indexing_preprocess_block(array &$variables): void {
  if (($variables['elements']['#plugin_id'] ?? '') !== 'social_ai_related_content') {
    return;
  }
  $variables['subtitle'] = t('in the community');
}
