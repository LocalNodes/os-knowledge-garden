{#
/**
 * @file
 * Template for the community-wide AI search page.
 */
#}
<div class="ai-search-wrapper">
  <div class="ai-search-header">
    <p class="ai-search-description">{{ 'Search the community using AI-powered semantic search. Results are ranked by relevance to your question.'|t }}</p>
  </div>
  <form class="ai-search-form" role="search">
    <div class="form-group">
      <label for="ai-search-input" class="sr-only">{{ 'Search query'|t }}</label>
      <div class="input-group">
        <input type="text" id="ai-search-input" name="q"
               class="form-control" placeholder="{{ 'Ask a question or search the community...'|t }}"
               autocomplete="off" minlength="2" />
        <span class="input-group-btn">
          <button type="submit" class="btn btn-primary">{{ 'Search'|t }}</button>
        </span>
      </div>
    </div>
  </form>
  <div class="ai-search-status" style="display:none;"></div>
  <div class="ai-search-results"></div>
</div>
